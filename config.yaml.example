# AI Agent 설정 파일
# 이 파일을 config.yaml로 복사하여 사용하세요.

# API 키 설정 (우선순위: 이 파일 > .env > 환경변수)
# 보안이 중요한 환경에서는 .env 또는 환경변수 사용을 권장합니다.
# api_key: "sk-ant-..."

# LLM 설정
model: "claude-sonnet-4-6"
max_tokens: 8192
max_iterations: 15

# 작업 환경
work_dir: "workspace"
system_prompt_path: "prompts/system.md"

# 출력 형식: markdown | plain | json
output_format: "markdown"

# 스트리밍 출력 (향후 확장)
stream: true

# 디버그
verbose: false

# 세션 로그
log_session: true
log_dir: "logs"

# 데이터베이스 설정
db:
  # DB 타입: sqlite | postgresql | mysql | mssql
  type: "sqlite"
  path: "workspace/agent.db"   # sqlite 전용

  # PostgreSQL / MySQL / MSSQL 설정
  # host: "localhost"
  # port: 5432
  # database: "mydb"
  # user: "username"
  # password: "password"

  # MSSQL DSN 방식 (선택)
  # dsn: "MyDSN"
